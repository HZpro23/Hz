# Neon Postgres connection string (pooled connection recommended)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"

# Auth.js — generate with: npx auth secret
AUTH_SECRET=""

# Seed admin (used once by prisma/seed.ts to create the first مدير النظام)
SEED_ADMIN_NAME="مدير النظام"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""

# Cloudinary (Phase 3 — product image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
