SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""

# Cloudinary (Phase 3 — product image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

